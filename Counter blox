	local optionsFrame = Instance.new("Frame", parent)
	optionsFrame.Position, optionsFrame.Size, optionsFrame.BackgroundColor3, optionsFrame.Visible, optionsFrame.ZIndex = UDim2.fromOffset(125,y+34), UDim2.new(0,140,0,#options*28), Color3.fromRGB(45,45,45), false, 20
