Instance.new("UICorner", DiscordBtn).CornerRadius = UDim.new(0,6)

DiscordBtn.MouseEnter:Connect(function() DiscordBtn.BackgroundColor3, DiscordBtn.TextColor3 = Color3.fromRGB(80,30,30), Color3.fromRGB(255,120,120) end)
DiscordBtn.MouseLeave:Connect(function() DiscordBtn.BackgroundColor3, DiscordBtn.TextColor3 = Color3.fromRGB(60,20,20), Color3.fromRGB(255,100,100) end)
DiscordBtn.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if setclipboard then setclipboard(DISCORD_LINK); DiscordBtn.Text = "✅ Link Copiado!"; task.wait(2); DiscordBtn.Text = "🔗 Join Discord" end
	end
end)

-- Tab Switch
local function ShowPage(p) AimbotPage.Visible, VisualPage.Visible, DiscordPage.Visible, p.Visible = false, false, false, true end
TabAimbot.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then ShowPage(AimbotPage) end end)
TabVisual.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then ShowPage(VisualPage) end end)
TabDiscord.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then ShowPage(DiscordPage) end end)
ToggleButton.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then Panel.Visible = not Panel.Visible end end)
