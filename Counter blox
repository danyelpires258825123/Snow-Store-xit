-- Team Check
local function IsEnemy(plr) return not State.TeamCheck or not Player.Team or not plr.Team or plr.Team ~= Player.Team end

-- Aimbot
local function GetAimbotPart(char)
	if not char then return nil end
	if State.AimbotPart == "Cabeça" then return char:FindFirstChild("Head") end
	return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
end

local function ClearVision(part, char)
	local params = RaycastParams.new()
	params.FilterType, params.FilterDescendantsInstances = Enum.RaycastFilterType.Blacklist, {Player.Character, Camera}
	local ray = workspace:Raycast(Camera.CFrame.Position, part.Position-Camera.CFrame.Position, params)
	return not ray or ray.Instance:IsDescendantOf(char)
end

local function GetTarget()
	local closest, dist, center = nil, State.FOVSize, Camera.ViewportSize/2
	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character and IsEnemy(plr) then
			local part = GetAimbotPart(plr.Character)
			if part then
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					local pos, vis = Camera:WorldToViewportPoint(part.Position)
					if vis then
						local mag = (Vector2.new(pos.X,pos.Y)-center).Magnitude
						if mag < dist and (not State.WallCheck or ClearVision(part, plr.Character)) then
							dist, closest = mag, part
						end
					end
				end
			end
		end
	end
	return closest
end

-- ESP System
local ESP = {}
local FIXED_BOX_WIDTH, FIXED_BOX_HEIGHT, FIXED_BAR_WIDTH = 35, 55, 3

local function NewESP(plr)
	if plr == Player then return end
	local box = Drawing.new("Square"); box.Thickness, box.Filled, box.Visible = 1, false, false
	local healthBarBg = Drawing.new("Square"); healthBarBg.Thickness, healthBarBg.Filled, healthBarBg.Color, healthBarBg.Visible = 1, true, Color3.fromRGB(0,0,0), false
	local healthBarFill = Drawing.new("Square"); healthBarFill.Thickness, healthBarFill.Filled, healthBarFill.Visible = 1, true, false
	local skeletonLines = {}
	for i = 1, 15 do 
		local line = Drawing.new("Line")
		line.Thickness, line.Color, line.Visible = 1.5, Color3.fromRGB(255,0,0), false
		table.insert(skeletonLines, line)
	end
	local name = Drawing.new("Text"); name.Center, name.Outline, name.Size, name.Color, name.Visible = true, true, 12, Color3.new(1,1,1), false
	local dist = Drawing.new("Text"); dist.Center, dist.Outline, dist.Size, dist.Color, dist.Visible = true, true, 10, Color3.new(1,1,1), false
	local tracer = Drawing.new("Line"); tracer.Thickness, tracer.Color, tracer.Visible = 1, Color3.fromRGB(255,0,0), false
	ESP[plr] = {box=box, healthBarBg=healthBarBg, healthBarFill=healthBarFill, skeleton=skeletonLines, name=name, dist=dist, tracer=tracer}
end

for _, p in pairs(Players:GetPlayers()) do NewESP(p) end
Players.PlayerAdded:Connect(NewESP)
Players.PlayerRemoving:Connect(function(plr)
	if ESP[plr] then for _, v in pairs(ESP[plr]) do if typeof(v) == "table" then for _, l in pairs(v) do l:Remove() end else v:Remove() end end; ESP[plr] = nil end
end)

local function UpdateESP()
	for plr, obj in pairs(ESP) do
		local char = plr.Character
		if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") and char:FindFirstChildOfClass("Humanoid") then
			local hrp, head, hum = char.HumanoidRootPart, char.Head, char:FindFirstChildOfClass("Humanoid")
			local pos, vis = Camera:WorldToViewportPoint(hrp.Position)
			if vis then
				local distance, cx, cy = (hrp.Position-Camera.CFrame.Position).Magnitude, pos.X, pos.Y
				local bw, bh = FIXED_BOX_WIDTH, FIXED_BOX_HEIGHT
				local bPos = Vector2.new(cx-bw/2, cy-bh/2)
				local isEnemy = IsEnemy(plr)
				
				if State.ESP_Box then
					if isEnemy then
						obj.box.Size, obj.box.Position, obj.box.Color, obj.box.Visible = Vector2.new(bw,bh), bPos, Color3.fromRGB(255,0,0), true
						obj.dist.Text, obj.dist.Position, obj.dist.Size, obj.dist.Visible = math.floor(distance).."m", Vector2.new(cx,bPos.Y+bh+4), 10, true
					else
						obj.box.Size, obj.box.Position, obj.box.Color, obj.box.Visible = Vector2.new(bw,bh), bPos, Color3.fromRGB(100,200,255), true
						obj.dist.Visible = false
					end
				else
					obj.box.Visible, obj.dist.Visible = false, false
				end
				
				if State.ESP_Health and isEnemy then
					local hp = math.clamp(hum.Health/hum.MaxHealth,0,1)
					local bh2 = bh-2
					obj.healthBarBg.Size, obj.healthBarBg.Position, obj.healthBarBg.Visible = Vector2.new(FIXED_BAR_WIDTH,bh2), Vector2.new(bPos.X-6,bPos.Y+1), true
					obj.healthBarFill.Size = Vector2.new(FIXED_BAR_WIDTH-1,(bh2-1)*hp)
					obj.healthBarFill.Position = Vector2.new(bPos.X-5.5,bPos.Y+1+(bh2-1)*(1-hp)+0.5)
					obj.healthBarFill.Color = hp > 0.6 and Color3.fromRGB(0,255,0) or (hp > 0.3 and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,0,0))
					obj.healthBarFill.Visible = true
				else
					obj.healthBarBg.Visible, obj.healthBarFill.Visible = false, false
				end
				
				if State.ESP_Skeleton and isEnemy then
					local function gp(part, off)
						if char:FindFirstChild(part) then
							local p = char[part].Position + (off or Vector3.new(0,0,0))
							local sp, v = Camera:WorldToViewportPoint(p)
							if v then return Vector2.new(sp.X,sp.Y) end
						end
						return nil
					end
					
					-- Pontos compactos
					local head = gp("Head")
					local neck = gp("Head", Vector3.new(0,-0.3,0))
					local torso = gp("UpperTorso") or gp("Torso")
					local pelvis = gp("LowerTorso") or gp("Torso", Vector3.new(0,-0.8,0))
					
					-- Braços
					local lShoulder = gp("LeftUpperArm") or gp("Left Arm", Vector3.new(0,0.3,0))
					local lElbow = gp("LeftLowerArm") or gp("Left Arm")
					local lHand = gp("LeftHand") or gp("Left Arm", Vector3.new(0,-0.3,0))
					
					local rShoulder = gp("RightUpperArm") or gp("Right Arm", Vector3.new(0,0.3,0))
					local rElbow = gp("RightLowerArm") or gp("Right Arm")
					local rHand = gp("RightHand") or gp("Right Arm", Vector3.new(0,-0.3,0))
					
					-- Pernas
					local lHip = gp("LeftUpperLeg") or gp("Left Leg", Vector3.new(0,0.3,0))
					local lKnee = gp("LeftLowerLeg") or gp("Left Leg")
					local lFoot = gp("LeftFoot") or gp("Left Leg", Vector3.new(0,-0.3,0))
					
					local rHip = gp("RightUpperLeg") or gp("Right Leg", Vector3.new(0,0.3,0))
					local rKnee = gp("RightLowerLeg") or gp("Right Leg")
					local rFoot = gp("RightFoot") or gp("Right Leg", Vector3.new(0,-0.3,0))
					
					-- 15 linhas: cabeça, tronco, braços, pernas
					local lines = {
						{head, neck},           -- 1: Cabeça
						{neck, torso},          -- 2: Pescoço
						{torso, pelvis},        -- 3: Tronco
						{neck, lShoulder},      -- 4: Braço esq cima
						{lShoulder, lElbow},    -- 5: Cotovelo esq
						{lElbow, lHand},        -- 6: Mão esq
						{neck, rShoulder},      -- 7: Braço dir cima
						{rShoulder, rElbow},    -- 8: Cotovelo dir
						{rElbow, rHand},        -- 9: Mão dir
						{pelvis, lHip},         -- 10: Perna esq cima
						{lHip, lKnee},          -- 11: Joelho esq
						{lKnee, lFoot},         -- 12: Pé esq
						{pelvis, rHip},         -- 13: Perna dir cima
						{rHip, rKnee},          -- 14: Joelho dir
						{rKnee, rFoot},         -- 15: Pé dir
					}
					
					for i=1,15 do
						local c = lines[i]
						if c and c[1] and c[2] and obj.skeleton[i] then 
							obj.skeleton[i].From, obj.skeleton[i].To, obj.skeleton[i].Visible = c[1], c[2], true 
						elseif obj.skeleton[i] then 
							obj.skeleton[i].Visible = false 
						end
					end
				else
					for _, l in ipairs(obj.skeleton) do l.Visible = false end
				end
				
				if State.ESP_Name and isEnemy then
					obj.name.Text, obj.name.Position, obj.name.Size, obj.name.Color, obj.name.Visible = plr.Name, Vector2.new(cx,bPos.Y-12), 12, Color3.new(1,1,1), true
				else
					obj.name.Visible = false
				end
				
				if State.Tracer and isEnemy then
					obj.tracer.From, obj.tracer.To, obj.tracer.Visible = Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y), Vector2.new(cx,bPos.Y+bh), true
				else
					obj.tracer.Visible = false
				end
			else
				for k, v in pairs(obj) do if k == "skeleton" then for _, l in ipairs(v) do l.Visible = false end else v.Visible = false end end
			end
		else
			for k, v in pairs(obj) do if k == "skeleton" then for _, l in ipairs(v) do l.Visible = false end else v.Visible = false end end
		end
	end
end

