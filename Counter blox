-- Slider (PC + Mobile)
local function CreateSlider(parent, text, y, min, max, default, callback)
	local container = Instance.new("Frame", parent)
	container.Size, container.Position, container.BackgroundColor3 = UDim2.new(0.9,0,0,55), UDim2.fromOffset(15,y), Color3.fromRGB(35,35,35)
	Instance.new("UICorner", container).CornerRadius = UDim.new(0,8)
	
	local label = Instance.new("TextLabel", container)
	label.Size, label.Position, label.BackgroundTransparency, label.Text, label.TextColor3, label.Font, label.TextSize, label.TextXAlignment = UDim2.new(1,-20,0,22), UDim2.fromOffset(10,6), 1, text..": "..default, Color3.new(1,1,1), Enum.Font.GothamSemibold, 12, Enum.TextXAlignment.Left
	
	local track = Instance.new("Frame", container)
	track.Position, track.Size, track.BackgroundColor3 = UDim2.fromOffset(12,32), UDim2.new(1,-24,0,8), Color3.fromRGB(50,50,50)
	Instance.new("UICorner", track).CornerRadius = UDim.new(0,4)
	
	local fill = Instance.new("Frame", track)
	fill.BackgroundColor3, fill.Size, fill.BorderSizePixel = Color3.fromRGB(200,40,40), UDim2.fromScale((default-min)/(max-min),1), 0
	Instance.new("UICorner", fill).CornerRadius = UDim.new(0,4)
	
	local thumb = Instance.new("Frame", track)
	thumb.Size, thumb.Position, thumb.BackgroundColor3, thumb.BorderSizePixel = UDim2.fromOffset(16,16), UDim2.new((default-min)/(max-min),-8,0.5,-8), Color3.fromRGB(255,255,255), 0
	Instance.new("UICorner", thumb).CornerRadius = UDim.new(1,0)
	
	local dragging = false
	
	local function Update(x)
		local clamped = math.clamp(x,0,1)
		fill.Size, thumb.Position = UDim2.fromScale(clamped,1), UDim2.new(clamped,-8,0.5,-8)
		local value = math.floor(min+(max-min)*clamped)
		label.Text = text..": "..value
		callback(value)
	end
	
	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true; Panel.Draggable = false; Update((input.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X)
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			Update((input.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X)
		end
	end)
	
	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging, Panel.Draggable = false, true
		end
	end)
end

