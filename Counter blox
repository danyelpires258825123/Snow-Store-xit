-- Checkbox
local function CreateCheckbox(parent, text, y, callback)
	local container = Instance.new("Frame", parent)
	container.Size, container.Position, container.BackgroundColor3 = UDim2.new(0.9,0,0,34), UDim2.fromOffset(15,y), Color3.fromRGB(35,35,35)
	Instance.new("UICorner", container).CornerRadius = UDim.new(0,8)
	
	local checkbox = Instance.new("Frame", container)
	checkbox.Size, checkbox.Position, checkbox.BackgroundColor3, checkbox.BorderSizePixel, checkbox.BorderColor3 = UDim2.fromOffset(22,22), UDim2.fromOffset(10,6), Color3.fromRGB(0,0,0), 2, Color3.fromRGB(60,60,60)
	Instance.new("UICorner", checkbox).CornerRadius = UDim.new(0,5)
	
	local checkmark = Instance.new("TextLabel", checkbox)
	checkmark.Size, checkmark.BackgroundTransparency, checkmark.Text, checkmark.TextColor3, checkmark.Font, checkmark.TextSize, checkmark.Visible = UDim2.new(1,0,1,0), 1, "✓", Color3.new(1,1,1), Enum.Font.GothamBold, 16, false
	
	local label = Instance.new("TextLabel", container)
	label.Position, label.Size, label.BackgroundTransparency, label.Text, label.TextColor3, label.Font, label.TextSize, label.TextXAlignment = UDim2.fromOffset(40,0), UDim2.new(1,-50,1,0), 1, text, Color3.new(1,1,1), Enum.Font.GothamSemibold, 13, Enum.TextXAlignment.Left
	
	local btn, state = Instance.new("TextButton", container), false
	btn.Size, btn.BackgroundTransparency, btn.Text = UDim2.new(1,0,1,0), 1, ""
	
	local function Update()
		checkbox.BackgroundColor3 = state and Color3.fromRGB(200,30,30) or Color3.fromRGB(0,0,0)
		checkbox.BorderColor3 = state and Color3.fromRGB(255,80,80) or Color3.fromRGB(60,60,60)
		checkmark.Visible = state
	end
	
	btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			state = not state; Update(); callback(state)
		end
	end)
	btn.MouseEnter:Connect(function() container.BackgroundColor3 = Color3.fromRGB(45,45,45) end)
	btn.MouseLeave:Connect(function() container.BackgroundColor3 = Color3.fromRGB(35,35,35) end)
	return container
end

